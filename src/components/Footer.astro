---
import { CONTACT_EMAIL, CONTACT_CITY, WHATSAPP_URL } from "../consts";
const today = new Date();
---

<footer>
	<div class="container foot">
		<div>
			<p class="foot-brand">Víctor Kuminov</p>
			<p class="muted">Webs y tiendas online que de verdad venden.<br />{CONTACT_CITY} · España</p>
		</div>
		<div>
			<p class="foot-title">Contacto</p>
			<p><a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a></p>
			<p><a href={WHATSAPP_URL}>WhatsApp</a></p>
		</div>
		<div>
			<p class="foot-title">Legal</p>
			<p><a href="/legal/aviso-legal">Aviso legal</a></p>
			<p><a href="/legal/privacidad">Política de privacidad</a></p>
			<p><a href="/legal/cookies">Política de cookies</a></p>
		</div>
	</div>
	<p class="copy muted">&copy; {today.getFullYear()} Víctor Kuminov · Autónomo en Asturias</p>
</footer>

<style>
	footer {
		background: var(--sand);
		border-top: 1px solid rgb(var(--gray-light));
		padding: 3rem 0 2rem;
		margin-top: 2rem;
	}
	.foot {
		display: grid;
		gap: 1.5rem;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
	}
	.foot p { margin: 0 0 0.3rem; }
	.foot-brand { font-weight: 700; font-size: 1.1rem; color: var(--accent-dark); }
	.foot-title { font-weight: 700; margin-bottom: 0.5rem !important; }
	.foot a { color: rgb(var(--gray-dark)); }
	.copy { text-align: center; margin-top: 2rem; font-size: 0.9rem; }
</style>
