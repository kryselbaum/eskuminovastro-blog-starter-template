---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	image?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = '/img/og.jpg' } = Astro.props;
const imageURL = new URL(image, Astro.site);

const orgSchema = {
	"@context": "https://schema.org",
	"@type": "ProfessionalService",
	name: "Víctor Kuminov",
	alternateName: "kuminov.es",
	description:
		"Desarrollo y reparación de webs y tiendas online para negocios de Asturias.",
	url: "https://kuminov.es",
	image: imageURL.toString(),
	email: "victor.kuminov@gmail.com",
	telephone: "+34637235634",
	priceRange: "€€",
	address: {
		"@type": "PostalAddress",
		addressLocality: "Avilés",
		addressRegion: "Asturias",
		addressCountry: "ES",
	},
	areaServed: "Asturias, España",
	knowsLanguage: ["es", "en"],
	founder: { "@type": "Person", name: "Víctor Kuminov" },
};
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Víctor Kuminov" />
<meta property="og:locale" content="es_ES" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:image:secure_url" content={imageURL} />
<meta property="og:image:type" content="image/jpeg" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="Víctor Kuminov — webs y tiendas online en Asturias" />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageURL} />
<meta property="twitter:image:alt" content="Víctor Kuminov — webs y tiendas online en Asturias" />

<!-- Schema.org -->
<script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
