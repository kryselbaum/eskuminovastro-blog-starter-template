---
import HeaderLink from "./HeaderLink.astro";
import { WHATSAPP_URL } from "../consts";
---

<header>
	<nav class="container">
		<a class="brand" href="/">Víctor Kuminov</a>
		<button class="menu-toggle" aria-label="Menú" aria-expanded="false">☰</button>
		<div class="internal-links">
			<HeaderLink href="/">Inicio</HeaderLink>
			<HeaderLink href="/servicios">Servicios</HeaderLink>
			<HeaderLink href="/casos">Casos</HeaderLink>
			<HeaderLink href="/precios">Precios</HeaderLink>
			<HeaderLink href="/sobre-mi">Sobre mí</HeaderLink>
			<HeaderLink href="/contacto">Contacto</HeaderLink>
			<a class="btn btn--wa header-cta" href={WHATSAPP_URL}>WhatsApp</a>
		</div>
	</nav>
</header>

<script>
	const btn = document.querySelector(".menu-toggle");
	const links = document.querySelector(".internal-links");
	btn?.addEventListener("click", () => {
		const open = links?.classList.toggle("open");
		btn.setAttribute("aria-expanded", String(open));
	});
</script>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: rgba(250, 247, 242, 0.92);
		backdrop-filter: blur(8px);
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.6em 0;
		gap: 1rem;
	}
	.brand {
		font-weight: 700;
		font-size: 1.15rem;
		color: var(--accent-dark);
		text-decoration: none;
		white-space: nowrap;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.3rem 1rem;
		flex-wrap: wrap;
	}
	.internal-links :global(a) {
		color: rgb(var(--gray-dark));
		text-decoration: none;
		padding: 0.3em 0;
	}
	.internal-links :global(a.active) {
		color: var(--accent);
		font-weight: 700;
		text-decoration: none;
	}
	.header-cta { color: #0b3d23 !important; padding: 0.5em 1.1em; }
	.menu-toggle {
		display: none;
		background: none;
		border: 0;
		font-size: 1.6rem;
		cursor: pointer;
		color: var(--accent-dark);
	}
	@media (max-width: 820px) {
		.menu-toggle { display: block; }
		.internal-links {
			display: none;
			width: 100%;
			flex-direction: column;
			align-items: flex-start;
			padding-bottom: 0.8rem;
		}
		.internal-links.open { display: flex; }
		nav { flex-wrap: wrap; }
	}
</style>
